import alu;
import rf;
import ifetch;
import cpu;
import mem;

export mod Top {
    incoming clock : Clock;
    incoming reset : Bit;
    outgoing fin : Bit;

    reg cycle : Word[32] on clock;
    cycle <= if reset { 0w32 } else { cycle + 1w32 };

    mod cpu of cpu::Cpu;
    cpu.clock := clock;
    cpu.reset := reset;

    mod mem of mem::Mem;
    mod instr_mem of mem::Rom;

    fin := cpu.is_break;
}
