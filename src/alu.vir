import opcode

mod Alu {
    incoming a : Word[32]
    incoming b : Word[32]
    outgoing z : Word[32]

    incoming op : opcode::AluOpcode

    z := match op {
        case #Add => a + b
        case #Sub => a - b
        case #And => a & b
        case #Or  => a | b
        case #Xor => a ^ b
        case #Eq  => zext(a == b)
        case #Neq => zext(a != b)
        case #Lt  => zext(a < b)
        case #Gte => zext(a >= b)
    }
}
