import opcode;

mod Alu {
    incoming a : Word[32];
    incoming b : Word[32];
    outgoing z : Word[32];

    incoming op : opcode::AluOpcode;

    z := match op {
        #Add => a + b;
        #Sub => a - b;
        #And => a & b;
        #Or  => a | b;
        #Xor => a ^ b;
        #Eq  => zext(a == b);
        #Neq => zext(a != b);
        #Lt  => zext(a < b);
        #Gte => zext(a >= b);
    };
}
